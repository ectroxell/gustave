{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": 1
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/regen-schema-doc.sh",
            "statusMessage": "Checking if DATABASE_SCHEMA.md needs regeneration"
          }
        ]
      }
    ]
  }
}
