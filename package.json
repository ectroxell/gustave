{
  "name": "gustave",
  "version": "1.0.0",
  "description": "Claude Code test project",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "start": "concurrently -n api,client -c blue,green \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:reset": "rm -f data/gustave.db* && npm run db:push && npm run db:seed",
    "db:schema-doc": "tsx scripts/generate-schema-doc.ts",
    "typecheck": "vue-tsc --noEmit -p tsconfig.client.json && tsc --noEmit -p tsconfig.server.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:client": "vitest run --project client",
    "test:server": "vitest run --project server",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "volta": {
    "node": "24.8.0",
    "npm": "11.6.0"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.9",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "eslint-plugin-testing-library": "^7.16.0",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.3",
    "msw": "^2.12.10",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
